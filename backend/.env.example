# 强制使用本地 Mock 规则引擎（比赛演示推荐，避免误走真实 LLM）
USE_MOCK_LLM=true

# 若 USE_MOCK_LLM=false，可配置以下项连接真实 LLM
API_BASE=https://api.openai.com/v1
API_KEY=
MODEL_NAME=gpt-4o-mini

# Database
DATABASE_URL=sqlite:///./agentshield.db

# Sandbox directory for file/shell tools
SANDBOX_DIR=./app/sandbox

# JWT 鉴权（演示账号见 README）
JWT_SECRET=agentshield-demo-secret-change-in-production
JWT_EXPIRE_HOURS=24
# 设为 true 可跳过鉴权（仅测试用）
AUTH_DISABLED=false

# 局域网演示：后端监听地址与 CORS
HOST=0.0.0.0
PORT=8000
ALLOW_LAN=true
# 生产部署示例（见 deploy/DEPLOY.md）：
# HOST=127.0.0.1
# PORT=8001
# ALLOW_LAN=false
# CORS_ORIGINS=https://agentshieldtop.xyz,https://www.agentshieldtop.xyz

# 自有策略（设置后优先于演示场景包，真正即插即用）
# POLICY_FILE=./config/my_policy.yaml
