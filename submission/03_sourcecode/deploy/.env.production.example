# AgentShield 生产环境配置（复制为 backend/.env 后修改）

USE_MOCK_LLM=true
AUTH_DISABLED=false

# 务必改为随机长字符串（openssl rand -hex 32）
JWT_SECRET=请替换为随机密钥
JWT_EXPIRE_HOURS=24

HOST=127.0.0.1
PORT=8001

# 生产环境配置（复制为 backend/.env 后修改）

USE_MOCK_LLM=true
AUTH_DISABLED=false

JWT_SECRET=请替换为随机密钥
JWT_EXPIRE_HOURS=24

HOST=127.0.0.1
PORT=8001

# 当前线上演示：IP:8088（备案前）
ALLOW_LAN=true
CORS_ORIGINS=http://114.215.209.144:8088

# 域名备案完成后可追加：
# CORS_ORIGINS=http://114.215.209.144:8088,https://agentshieldtop.xyz,https://www.agentshieldtop.xyz

DATABASE_URL=sqlite:///./agentshield.db
SANDBOX_DIR=./app/sandbox

SEMANTIC_CHECK_ENABLED=true
SEMANTIC_CHECK_MODE=local

# 若需真实 LLM 规划（可选）
# USE_MOCK_LLM=false
# API_KEY=
# API_BASE=https://api.openai.com/v1
# MODEL_NAME=gpt-4o-mini
